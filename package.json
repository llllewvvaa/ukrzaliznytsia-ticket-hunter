{
  "name": "uz-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chrome MV3 extension that hunts and reserves Ukrzaliznytsia (UZ) train tickets on booking.uz.gov.ua",
  "keywords": [
    "ukrzaliznytsia",
    "uz",
    "ukraine",
    "ukrainian-railways",
    "train-tickets",
    "railway",
    "booking-uz",
    "chrome-extension",
    "manifest-v3",
    "wxt",
    "укрзалізниця",
    "квитки-на-потяг",
    "залізничні-квитки",
    "бронювання-квитків"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/llllewvvaa/ukrzaliznytsia-ticket-hunter.git"
  },
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.7.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/chrome": "^0.2.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@wxt-dev/module-react": "^1.2.2",
    "happy-dom": "^20.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wxt": "^0.20.27"
  }
}
