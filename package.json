{
  "name": "uz-extension",
  "version": "1.1.5",
  "private": true,
  "type": "module",
  "description": "Chrome MV3 extension that hunts and reserves Ukrzaliznytsia (UZ) train tickets on booking.uz.gov.ua",
  "keywords": [
    "ukrzaliznytsia",
    "uz",
    "ukraine",
    "ukrainian-railways",
    "train-tickets",
    "railway",
    "booking-uz",
    "chrome-extension",
    "manifest-v3",
    "wxt",
    "укрзалізниця",
    "квитки-на-потяг",
    "залізничні-квитки",
    "бронювання-квитків"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/llllewvvaa/ukrzaliznytsia-ticket-hunter.git"
  },
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "wxt prepare && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "wxt prepare",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,css,json,md}": "prettier --write",
    "*.{ts,tsx,js}": "eslint --fix"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/chrome": "^0.2.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "happy-dom": "^20.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.5",
    "wxt": "^0.20.27"
  }
}
